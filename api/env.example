# Copy this to .env and fill in real values.
# .env is gitignored and never committed.

# Absolute path to the directory containing your journal file
JOURNAL_DIR=/home/server/git_projects/repos/2026.ledger
JOURNAL_DIR=/home/server/git_projects/repos/2026.ledger/2026.journal

# A strong random secret — generate with: openssl rand -hex 32
BEARER_TOKEN=YOUR_TOKEN

# Currency symbol used in your journal
DEFAULT_CURRENCY=$

HLEDGER_BIN=/opt/homebrew/bin/hledger
