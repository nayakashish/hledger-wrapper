[Unit]
Description=hledger API
After=network.target

[Service]
Type=simple
User=server
WorkingDirectory=/home/server/hledger_wrapper/api
EnvironmentFile=/home/server/hledger_wrapper/api/.env
ExecStart=/home/server/hledger_wrapper/api/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
